@startuml SkywalkerFramework

title SkywalkerFramework 当前架构（2026-03-03）

skinparam classAttributeIconSize 0
skinparam packageStyle rectangle
hide empty members

package "Core" {
	class SSFObject
	class SSFObjectManager
	class SSFModule
	class SSFPlugin
	class SSFPluginManager
	class SSFGameplayServiceGateway {
		+ValidateToken(Token)
		+LoadPlayer(PlayerId)
		+EnterWorld(PlayerId, WorldId)
		+LeaveWorld(PlayerId, WorldId)
		+StartReplayRecord(SessionId)
		+StopReplayRecord()
		+StartReplayPlay(SessionId)
		+StopReplayPlay()
		+GetReplayRecordStats()
		+GetReplayPlayStats()
		+GetReplayEventByIndex(EventIndex)
		+GetReplayEventsRange(StartIndex, Count)
		+FindReplayEventsByKeyword(Keyword, MaxCount)
		+SetAIStrategy(Strategy)
		+GetAIStats()
		+GetAIStrategies()
		+GetAIAudit()
		+ClearAIAudit()
	}
}

class CSkywalkerFramework

SSFObject <|-- CSkywalkerFramework
SSFObject <|-- SSFObjectManager
SSFObject <|-- SSFModule
SSFObjectManager <|-- SSFPlugin
SSFObjectManager <|-- SSFPluginManager

CSkywalkerFramework o-- SSFPluginManager : 管理
SSFPluginManager *-- "1..*" SSFPlugin : 加载/卸载
SSFPlugin *-- "1..*" SSFModule : 注册模块

package "Plugin: Network" {
	class SSFPlugin_Network
	class SSFModule_NetworkServer
	class SSFModule_NetworkClient
}

package "Plugin: CommandLine" {
	class SSFPlugin_CommandLine
	class SSFModule_OS
	class SSFModule_AdminCommand
}

package "Plugin: AI" {
	class SSFPlugin_AI
	class SSFModule_AIRuntime
}

package "Plugin: Video" {
	class SSFPlugin_Video
	class SSFModule_ReplayRecorder
	class SSFModule_ReplayPlayer
}

package "Plugin: Auth" {
	class SSFPlugin_Auth
	class SSFModule_Auth
}

package "Plugin: DB" {
	class SSFPlugin_DB
	class SSFModule_DBAccess
	class SSFModule_PlayerRepository
}

package "Plugin: Level" {
	class SSFPlugin_Level
	class SSFModule_WorldManager
}

package "Plugin: Actor" {
	class SSFPlugin_Actor
	class SSFModule_ActorRuntime
}

package "Plugin: Profiler" {
	class SSFPlugin_Profiler
	class SSFModule_Metrics
	class SSFModule_HealthCheck
}

package "Plugin: Test" {
	class SSFPlugin_Test
	class SSFModule_TestOne
	class SSFModule_TestTwo
	class SSFModule_TestThree
}

SSFPlugin <|-- SSFPlugin_Network
SSFPlugin <|-- SSFPlugin_CommandLine
SSFPlugin <|-- SSFPlugin_AI
SSFPlugin <|-- SSFPlugin_Video
SSFPlugin <|-- SSFPlugin_Auth
SSFPlugin <|-- SSFPlugin_DB
SSFPlugin <|-- SSFPlugin_Level
SSFPlugin <|-- SSFPlugin_Actor
SSFPlugin <|-- SSFPlugin_Profiler
SSFPlugin <|-- SSFPlugin_Test

SSFModule <|-- SSFModule_NetworkServer
SSFModule <|-- SSFModule_NetworkClient
SSFModule <|-- SSFModule_OS
SSFModule <|-- SSFModule_AdminCommand
SSFModule <|-- SSFModule_AIRuntime
SSFModule <|-- SSFModule_ReplayRecorder
SSFModule <|-- SSFModule_ReplayPlayer
SSFModule <|-- SSFModule_Auth
SSFModule <|-- SSFModule_DBAccess
SSFModule <|-- SSFModule_PlayerRepository
SSFModule <|-- SSFModule_WorldManager
SSFModule <|-- SSFModule_ActorRuntime
SSFModule <|-- SSFModule_Metrics
SSFModule <|-- SSFModule_HealthCheck
SSFModule <|-- SSFModule_TestOne
SSFModule <|-- SSFModule_TestTwo
SSFModule <|-- SSFModule_TestThree

SSFPlugin_Network *-- SSFModule_NetworkServer
SSFPlugin_Network *-- SSFModule_NetworkClient
SSFPlugin_CommandLine *-- SSFModule_OS
SSFPlugin_CommandLine *-- SSFModule_AdminCommand
SSFPlugin_AI *-- SSFModule_AIRuntime
SSFPlugin_Video *-- SSFModule_ReplayRecorder
SSFPlugin_Video *-- SSFModule_ReplayPlayer
SSFPlugin_Auth *-- SSFModule_Auth
SSFPlugin_DB *-- SSFModule_DBAccess
SSFPlugin_DB *-- SSFModule_PlayerRepository
SSFPlugin_Level *-- SSFModule_WorldManager
SSFPlugin_Actor *-- SSFModule_ActorRuntime
SSFPlugin_Profiler *-- SSFModule_Metrics
SSFPlugin_Profiler *-- SSFModule_HealthCheck
SSFPlugin_Test *-- SSFModule_TestOne
SSFPlugin_Test *-- SSFModule_TestTwo
SSFPlugin_Test *-- SSFModule_TestThree

SSFModule_NetworkServer ..> SSFGameplayServiceGateway : 登录/会话/业务调用
SSFModule_AdminCommand ..> SSFGameplayServiceGateway : 运维命令透传
SSFModule_Auth ..> SSFGameplayServiceGateway : RegisterAuthValidator
SSFModule_PlayerRepository ..> SSFGameplayServiceGateway : RegisterPlayerLoader
SSFModule_WorldManager ..> SSFGameplayServiceGateway : RegisterWorldEnter/Leave
SSFModule_AIRuntime ..> SSFGameplayServiceGateway : RegisterAI* 回调
SSFModule_ReplayRecorder ..> SSFGameplayServiceGateway : RegisterReplayRecord*
SSFModule_ReplayPlayer ..> SSFGameplayServiceGateway : RegisterReplayPlay* / Query*

legend right
  说明:
  - 实线: 继承/组合关系
  - 虚线: 通过核心网关进行跨插件协作
  - 网关是 Network、CommandLine 与业务插件解耦的关键枢纽
endlegend

@enduml
